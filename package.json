{
  "name": "code-challenge-tl",
  "version": "0.1.0",
  "private": true,
  "description": "Challenge 1 payment settlement pipeline scaffold",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "start:api": "node -r ts-node/register/transpile-only -r tsconfig-paths/register apps/api/src/main.ts",
    "start:relay": "node -r ts-node/register/transpile-only -r tsconfig-paths/register apps/relay/src/main.ts",
    "db:migrate": "node -r ts-node/register/transpile-only -r tsconfig-paths/register apps/api/src/database/run-migrations.ts",
    "infra:up": "docker compose up -d postgres kafka && docker compose run --rm kafka-init-topics && npm run db:migrate",
    "infra:down": "docker compose down",
    "test": "jest --passWithNoTests"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.15",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.15",
    "@nestjs/platform-express": "^10.4.15",
    "@nestjs/typeorm": "^10.0.2",
    "kafkajs": "^2.2.4",
    "pg": "^8.13.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "typeorm": "^0.3.20"
  },
  "devDependencies": {
    "@nestjs/testing": "^10.4.15",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.2",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.2"
  }
}
